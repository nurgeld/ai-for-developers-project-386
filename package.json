{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "concurrently \"npm run mock:api\" \"vite --mode mock\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "compile:api": "tsp compile api/main.tsp --emit @typespec/openapi3 && cp tsp-output/@typespec/openapi3/openapi.yaml src/api/openapi.json",
    "generate:types": "openapi-typescript src/api/openapi.json -o src/api/generated.ts",
    "mock:api": "prism mock src/api/openapi.json -p 4010"
  },
  "dependencies": {
    "@mantine/core": "^9.0.0",
    "@mantine/dates": "^9.0.0",
    "@mantine/form": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@typespec/compiler": "^1.10.0",
    "@typespec/http": "^1.10.0",
    "@typespec/openapi3": "^1.10.0",
    "@typespec/rest": "^0.80.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stoplight/prism-cli": "^5.8.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.6.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
